# Dev-mode Dockerfile for the GUI.
# Source is mounted as a volume for hot-reload; this image just provides
# the Node runtime and installs dependencies.
#
# Build context: monorepo root (users-module/) — needed because pnpm
# workspace hoists deps to the root node_modules. The gui/.yalc/ dir
# (gitignored, populated by `make link-core` at the repo root) must
# also be present so pnpm can resolve @moduleforge/core-gui via the
# file: spec in gui/package.json.

FROM node:24-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace config + lockfile for dependency install.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY gui/package.json ./gui/
# Yalc-linked local packages (e.g. @moduleforge/core-gui) — populated by
# `make link-core` from the repo root. The dir must exist; fail loudly
# at build time if not, rather than silently fall back to a stale cache.
COPY gui/.yalc ./gui/.yalc

RUN pnpm install --frozen-lockfile

WORKDIR /app/gui

EXPOSE 3000

CMD ["npx", "next", "dev", "--hostname", "0.0.0.0"]
