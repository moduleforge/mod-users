# =============================================================================
# users-module local dev environment
# =============================================================================
# Copy to .env and edit. The defaults below are safe for local development;
# override for any non-local deployment.
#
# docker-compose.yml, the API server, and the GUI all read from this file.
# =============================================================================

# ---- Deployment mode --------------------------------------------------------
DEPLOY_MODE=local

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=users
POSTGRES_PASSWORD=users
POSTGRES_DB=users
POSTGRES_PORT=5432
# API reads DB_URL directly:
DB_URL=postgresql://users:users@localhost:5432/users?sslmode=disable

# ---- API server -------------------------------------------------------------
SERVER_ADDR=:8080
GUI_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ---- Authelia / OIDC --------------------------------------------------------
AUTHELIA_PORT=9091

# Secrets must be >= 32 chars. Change these for anything beyond local dev.
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=change-me-jwt-secret-at-least-32-chars-long
AUTHELIA_SESSION_SECRET=change-me-session-secret-at-least-32-chars
AUTHELIA_STORAGE_ENCRYPTION_KEY=change-me-storage-encryption-key-at-least-32
AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET=change-me-oidc-hmac-secret-at-least-32

# OIDC client config used by the API and GUI to initiate the OIDC flow.
OIDC_ISSUER_URL=http://localhost:9091
OIDC_CLIENT_ID=users-api
OIDC_CLIENT_SECRET=change-me-users-api-client-secret
OIDC_CLAIM_STYLE=authelia
OIDC_ADMIN_ROLE=admin
OIDC_REDIRECT_URI_API=http://localhost:8080/v1/auth/oidc/callback
OIDC_REDIRECT_URI_GUI=http://localhost:3000/api/auth/oidc/callback
OIDC_SCOPES=openid profile email groups

# ---- Local auth (non-OIDC) --------------------------------------------------
JWT_SECRET=change-me-jwt-secret-for-local-auth-at-least-32-chars
LOCAL_ISSUER=users-module-local

# ---- MailHog / SMTP ---------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
MAILHOG_UI_PORT=8025

# ---- Timezone (used by Authelia container) -----------------------------------
TZ=UTC
